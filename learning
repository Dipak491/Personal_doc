String lastLogin = users.getUpdatedOn() != null
    ? new SimpleDateFormat("dd-MM-yyyy HH:mm").format(users.getUpdatedOn())
    : "First Login";
session.setAttribute("lastLoginTime", lastLogin);

// Update the login time
